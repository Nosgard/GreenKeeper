<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:Converters="clr-namespace:GreenKeeper.Converters">

    <Converters:DaysUntilCareConverter x:Key="DaysUntilCareConverter" />
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

    <DataTemplate x:Key="CareStatusCardTemplate">
        <Border Background="#2C2C2E"
            CornerRadius="14"
            Padding="14"
            Margin="0, 14, 0, 0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Icon-Box -->
                <Border Grid.Column="0"
                Background="{Binding IconBackground}"
                CornerRadius="10"
                Width="44"
                Height="44"
                Margin="0, 0, 12, 0"
                VerticalAlignment="Center">
                    <Image Source="{Binding IconSource}" />
                </Border>

                <!-- Subtitle container -->
                <StackPanel Grid.Column="1" Grid.ColumnSpan="2" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}"
                       Foreground="#F0F0EE"
                       FontSize="16"
                       FontWeight="SemiBold" />

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding DaysUntilDue, Converter={StaticResource DaysUntilCareConverter}}"
                           Foreground="#8A8A86"
                           FontSize="14" />
                    </StackPanel>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Grid.Column="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">

                    <Button Style="{StaticResource CareActionButton}"
                            Content="Complete"
                            Padding="10"
                            Margin="0, 0, 6, 0"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsAbleToComplete, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <Button Style="{StaticResource CareActionButton}"
                            Content="Edit"
                            Padding="10"
                            Margin="0, 0, 6, 0"
                            VerticalAlignment="Center" />

                    <Button Style="{StaticResource CareActionButton}"
                        Content="Remove"
                        Padding="10"
                        Margin="0, 0, 6, 0"
                        VerticalAlignment="Center"
                        Visibility="{Binding IsRemovable, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
            </Grid>
        </Border>
    </DataTemplate>
</ResourceDictionary>