<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:active="clr-namespace:GreenKeeper.ViewModels.CareStatuses.Active"
                    xmlns:passive="clr-namespace:GreenKeeper.ViewModels.CareStatuses.Passive">

    <DataTemplate x:Key="CareStatusCardTemplate">
        <Border Background="#2C2C2E"
            CornerRadius="14"
            Padding="14"
            Margin="0, 14, 0, 0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Icon-Box -->
                <Border Grid.Column="0"
                Background="{Binding IconBackground}"
                CornerRadius="10"
                Width="44"
                Height="44"
                Margin="0, 0, 12, 0"
                VerticalAlignment="Center">
                    <Image Source="{Binding IconSource}" />
                </Border>

                <!-- Subtitle container -->
                <StackPanel Grid.Column="1" Grid.ColumnSpan="2" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}"
                       Foreground="#F0F0EE"
                       FontSize="16"
                       FontWeight="SemiBold" />

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding StatusText}"
                           Foreground="#8A8A86"
                           FontSize="14" />
                    </StackPanel>
                </StackPanel>
                
                <!-- Buttons-->
                <!-- Will be filled via the implicit template of the actual type-->
                <ContentPresenter Grid.Column="3"
                                  Content="{Binding}"
                                  VerticalAlignment="Center" />
            </Grid>
        </Border>
    </DataTemplate>
    
    <!-- DataTemplates to set the right buttons for each care status -->

    <!-- Button-Set: Watering -->
    <DataTemplate DataType="{x:Type active:WateringStatusViewModel}">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Style="{StaticResource StatusCardActionButton}"
                    Content="Complete"
                    Padding="10"
                    Margin="0, 0, 6, 0"
                    Command="{Binding CompleteCommand}"
                    IsEnabled="{Binding IsCompletable}"/>
            <Button Style="{StaticResource StatusCardActionButton}"
                    Content="Edit"
                    Padding="10"
                    Command="{Binding EditCommand}" />
        </StackPanel>
    </DataTemplate>
    
    <!-- Button-Set: Fertilizing -->
    <DataTemplate DataType="{x:Type active:FertilizingStatusViewModel}">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Style="{StaticResource StatusCardActionButton}"
                    Content="Complete"
                    Padding="10"
                    Margin="0, 0, 6, 0"
                    Command="{Binding CompleteCommand}"
                    IsEnabled="{Binding IsCompletable}" />
            <Button Style="{StaticResource StatusCardActionButton}"
                    Content="Edit"
                    Padding="10"
                    Margin="0, 0, 6, 0"
                    Command="{Binding EditCommand}" />
            <Button Style="{StaticResource StatusCardActionButton}"
                    Content="Remove"
                    Padding="10"
                    Command="{Binding RemoveCommand}"/>
        </StackPanel>
    </DataTemplate>
    
    <!-- Button-Set: Sunlight -->
    <DataTemplate DataType="{x:Type passive:SunlightStatusViewModel}">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Style="{StaticResource StatusCardActionButton}"
                    Content="Edit"
                    Padding="10"
                    Margin="0, 0, 6, 0"
                    Command="{Binding EditCommand}" />
            <Button Style="{StaticResource StatusCardActionButton}"
                    Content="Remove"
                    Padding="10"
                    Command="{Binding RemoveCommand}"/>
        </StackPanel>
    </DataTemplate>
</ResourceDictionary>