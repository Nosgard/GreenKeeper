<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--ComboBox Style -->
    
    <!-- ComboBox Item -->
    <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#F0F0EE" />
        <Setter Property="Padding" Value="8, 6" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="itemBorder"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Hover for an entry in the unfolded list -->
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="itemBorder" Property="Background" Value="#2A2C34" />
                        </Trigger>
                        <!-- Currently selected entry -->
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="itemBorder" Property="Background" Value="#32343E" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- ComboBox Main Part -->
    <Style x:Key="DarkComboBox" TargetType="ComboBox">
        <Setter Property="Background" Value="#2C2C2E" />
        <Setter Property="BorderBrush" Value="#3A3D47" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="#F0F0EE" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="8, 6" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItem}" />
        <!-- Explicit ItemTemplate because DisplayMemberPath + internally created ControlTemplate cause wrong behavior by WPF -->
        <Setter Property="ItemTemplate">
            <Setter.Value>
                <DataTemplate>
                    <TextBlock Text="{Binding Value}" />
                </DataTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <!-- Visible frame + arrow to open the dropdown -->
                        <ToggleButton x:Name="toggleButton"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}"
                                      Padding="{TemplateBinding Padding}"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      Focusable="False"
                                      ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}"
                                            CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="24" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Dropdown-Arrow -->
                                            <Path Grid.Column="1"
                                                  Data="M 0 0 L 4 4 L 8 0 Z"
                                                  Fill="#8A8A86"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <!-- Show the selected value, when the dropdown is closed -->
                        <ContentPresenter x:Name="contentPresenter"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          IsHitTestVisible="False"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left" />

                        <!-- Unfoldable list of options -->
                        <Popup x:Name="popup"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Border Background="#2C2C2E"
                                    BorderBrush="#3A3D47"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Margin="0, 2, 0, 0"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="200">
                                <ScrollViewer>
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!-- Hover over the closed ComboBox -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="toggleButton" Property="Background" Value="#32343E" />
                        </Trigger>
                        <!-- Disabled-State -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="toggleButton" Property="Background" Value="#1E2028" />
                            <Setter TargetName="toggleButton" Property="BorderBrush" Value="#2A2C32" />
                            <Setter Property="Foreground" Value="#4A4A48" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>