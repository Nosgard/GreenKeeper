<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Big Dark Button -->
    <Style x:Key="BigDarkButton" TargetType="Button">
        <!-- Default properties -->
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="#3A3D47" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="#8A8A86"/>
        <Setter Property="FontSize" Value="24" />
        <Setter Property="Cursor" Value="Hand" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="4"
                        Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                    </Border>

                    <ControlTemplate.Triggers>
                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#2A2C34" />
                        </Trigger>

                        <!-- Pressed -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#32343E" />
                        </Trigger>

                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="#1E2028"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="#2A2C32"/>
                            <Setter Property="Foreground" Value="#4A4A48"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Medium Dark Button -->
    <Style x:Key="MediumDarkButton"
       TargetType="Button"
       BasedOn="{StaticResource BigDarkButton}">
        <Setter Property="FontSize" Value="16"/>
    </Style>
    
    <!-- Small Dark Button -->
    <Style x:Key="SmallDarkButton"
       TargetType="Button"
       BasedOn="{StaticResource BigDarkButton}">
        <Setter Property="FontSize" Value="14"/>
    </Style>
    
</ResourceDictionary>