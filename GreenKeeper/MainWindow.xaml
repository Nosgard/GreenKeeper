<Window x:Class="GreenKeeper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GreenKeeper"
        xmlns:Converters="clr-namespace:GreenKeeper.Converters"
        mc:Ignorable="d"
        Title="GreenKeeper" Height="650" Width="900">
    <Window.Resources>
        
    </Window.Resources>
    <Grid Background="#1A1C22">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Grid Background="#22242A" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="16, 20, 16, 12">
                <TextBlock Text="GreenKeeper"
                           Foreground="#F0F0EE"
                           FontSize="24"
                           FontWeight="SemiBold" />
            </StackPanel>

            <!-- Searchbar -->
            <Border Grid.Row="1"
                    Margin="10, 10, 10, 10"
                    Background="#2C2F38"
                    BorderBrush="#3A3D47"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="1"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#C8C8C4"
                             CaretBrush="#C8C8C4"
                             FontSize="13"
                             VerticalContentAlignment="Center"
                             Padding="0, 8, 10, 8">
                    </TextBox>
                </Grid>
            </Border>

            <!-- List of plants -->
            <ListView Grid.Row="2"
                      Background="Transparent"
                      BorderThickness="0"
                      Margin="6, 0, 6, 0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ItemsSource="{Binding Plants}"
                      SelectedItem="{Binding SelectedPlant, Mode=TwoWay}">

                <!-- Template for plant entries -->
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Margin="8, 0, 0, 0">
                            <TextBlock Text="{Binding Name}"
                                       Foreground="#F0F0EE"
                                       FontSize="24"
                                       FontWeight="Medium" />

                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Add-Button -->
            <Button Grid.Row="3"
                    Style="{StaticResource BigDarkButton}"
                    Margin="10, 8, 10, 12"
                    Padding="0, 10"
                    
                    Content="+  Add Plant"></Button>
        </Grid>

        <!-- Dashboard -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="50" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Navigation -->
            <Grid Grid.Row="0" VerticalAlignment="Center" Margin="16, 20, 16, 12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding SelectedPlant.Name}" Foreground="White" FontSize="28" FontWeight="Bold" />

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource MediumDarkButton}"
                            Padding="10"
                            Content="+  Add Schedule">

                    </Button>

                    <Button Style="{StaticResource MediumDarkButton}"
                            Margin="10, 0, 0, 0"
                            Padding="10"
                            Content="-  Delete Plant">
                    </Button>
                </StackPanel>

            </Grid>
            
            <Border Grid.Row="1" Height="1" Background="#444746" />

            <!-- Status -->
            <Grid Grid.Row="2">
                <StackPanel Margin="16, 0, 16, 12">
                    <TextBlock Text="Status"
                               Foreground="#F0F0EE"
                               FontSize="24"
                               FontWeight="SemiBold" />
                    
                    <!-- Status Cards (Watering, Nutrients, Sunlighting (missing)) -->
                    <ItemsControl ItemsSource="{Binding CareStatuses}"
                                  ItemTemplate="{StaticResource CareStatusCardTemplate}" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
