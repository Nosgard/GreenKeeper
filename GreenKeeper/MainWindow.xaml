<Window x:Class="GreenKeeper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GreenKeeper"
        mc:Ignorable="d"
        Title="GreenKeeper" Height="650" Width="900">
    
    <!-- Main Grid -->
    <Grid Background="#1A1C22">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Grid Background="#22242A" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="16, 20, 16, 12">
                <TextBlock Text="GreenKeeper"
                           Foreground="#F0F0EE"
                           FontSize="24"
                           FontWeight="SemiBold" />
            </StackPanel>

            <!-- Searchbar -->
            <Border Grid.Row="1"
                    Margin="10, 10, 10, 10"
                    Background="#2C2F38"
                    BorderBrush="#3A3D47"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="1"
                             x:Name="SearchTextBox"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#C8C8C4"
                             CaretBrush="#C8C8C4"
                             FontSize="13"
                             VerticalContentAlignment="Center"
                             Padding="10, 8, 10, 8">
                    </TextBox>
                    <TextBlock Grid.Column="1"
                               Text="Search..."
                               Foreground="#6A6A66"
                               FontSize="13"
                               Margin="10, 0, 0, 0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Text, ElementName=SearchTextBox}" Value="" />
                                            <Condition Binding="{Binding IsKeyboardFocused, ElementName=SearchTextBox}" Value="False" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- List of plants -->
            <ListView Grid.Row="2"
                      Background="Transparent"
                      BorderThickness="0"
                      Margin="6, 0, 6, 0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ItemsSource="{Binding Plants}"
                      SelectedItem="{Binding SelectedPlant, Mode=TwoWay}">

                <!-- Template for plant entries -->
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="8, 0, 0, 0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>


                            <TextBlock Grid.Column="0"
                                       Text="{Binding Name}"
                                       Foreground="#F0F0EE"
                                       FontSize="24"
                                       FontWeight="Medium"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Add-Button -->
            <Button Grid.Row="3"
                    Style="{StaticResource BigDarkButton}"
                    Margin="10, 8, 10, 12"
                    Padding="0, 10"
                    Content="+  Add Plant"
                    Command="{Binding AddPlantCommand}"/>
        </Grid>

        <!-- Dashboard -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="50" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Navigation -->
            <Grid Grid.Row="0" VerticalAlignment="Center" Margin="16, 20, 16, 12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           VerticalAlignment="Top"
                           Text="{Binding SelectedPlant.Name}"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="Bold"
                           TextWrapping="NoWrap"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding SelectedPlant.Name}" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Style="{StaticResource MediumDarkButton}"
                            Padding="10"
                            Content="+  Add Schedule"
                            Command="{Binding AddScheduleCommand}">

                    </Button>

                    <Button Style="{StaticResource MediumDarkButton}"
                            Margin="10, 0, 0, 0"
                            Padding="10"
                            Content="-  Delete Plant"
                            Command="{Binding DeletePlantCommand}">
                    </Button>
                </StackPanel>

            </Grid>
            
            <Border Grid.Row="1" Height="1" Background="#444746" />

            <!-- Status -->
            <Grid Grid.Row="2">
                <StackPanel Margin="16, 0, 16, 12">
                    <TextBlock Text="Status"
                               Foreground="#F0F0EE"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Visibility="{Binding IsPlantSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <!-- Status Cards (Watering, Nutrients, Sunlighting (missing)) -->
                    <ItemsControl ItemsSource="{Binding CareStatuses}"
                                  ItemTemplate="{StaticResource CareStatusCardTemplate}" />
                </StackPanel>
                
                <!-- Notes-Button -->
                <Button Style="{StaticResource MediumDarkButton}"
                        Content="View Notes"
                        Padding="10"
                        Margin="0, 0, 16, 16"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Command="{Binding OpenNotesCommand}"/>
                
                <!-- Debug-Section -->
                <Border Grid.Row="2"
                        Background="#2A1A1A"
                        BorderBrush="#5A2A2A"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10"
                        Margin="16, 0, 16, 80"
                        VerticalAlignment="Bottom"
                        Visibility="{Binding IsDebugBuild, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="DEBUG: Simulate"
                                   Foreground="#D08080"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="0, 0, 8, 0" />
                        
                        <TextBox Text="{Binding SimulationAmountText, UpdateSourceTrigger=PropertyChanged}"
                                 Width="40"
                                 Background="#2C2C2E"
                                 Foreground="#F0F0EE"
                                 CaretBrush="#F0F0EE"
                                 BorderThickness="1"
                                 BorderBrush="#3A3D47"
                                 Padding="4"
                                 FontSize="12"
                                 VerticalAlignment="Center" />

                        <ComboBox Style="{StaticResource DarkComboBox}"
                                  ItemsSource="{Binding AvailableSimulationUnits}"
                                  SelectedValuePath="Key"
                                  SelectedValue="{Binding SimulationUnit}"
                                  Width="90"
                                  Margin="6, 0, 0, 0" />

                        <Button Style="{StaticResource StatusCardActionButton}"
                                Content="Fast-forward"
                                Margin="6, 0, 0, 0"
                                Width="100"
                                Padding="6"
                                Command="{Binding SimulateTimePassingCommand}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
