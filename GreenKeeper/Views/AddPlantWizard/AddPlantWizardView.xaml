<Window x:Class="GreenKeeper.Views.AddPlantWizard.AddPlantWizardView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:steps="clr-namespace:GreenKeeper.ViewModels.AddPlantWizard.Steps"
        xmlns:activeSteps="clr-namespace:GreenKeeper.ViewModels.AddPlantWizard.Steps.Active"
        xmlns:passiveSteps="clr-namespace:GreenKeeper.ViewModels.AddPlantWizard.Steps.Passive"
        mc:Ignorable="d"
        Title="Add Plant" Height="300" Width="450"
        MinWidth="400"
        MinHeight="260"
        Background="#1A1C22"
        WindowStartupLocation="CenterOwner">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <DataTemplate DataType="{x:Type steps:PlantNameStepViewModel}">
            <StackPanel Margin="20">
                <TextBlock Text="Enter a name for the plant"
                       Foreground="#F0F0EE"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0, 0, 0, 12" />

                <TextBox Text="{Binding PlantName, UpdateSourceTrigger=PropertyChanged}"
                         MaxLength="50"
                         Background="#2C2C2E"
                         Foreground="#F0F0EE"
                         CaretBrush="#F0F0EE"
                         BorderThickness="1"
                         BorderBrush="#3A3D47"
                         Padding="8"
                         FontSize="14" />

                <TextBlock Text="{Binding CharactersRemaining, StringFormat='{}{0} characters remaining'}"
                           Foreground="#6A6A66"
                           FontSize="12"
                           Margin="0, 6, 0, 0" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type activeSteps:WateringStepViewModel}">
            <StackPanel Margin="20">
                <TextBlock Text="* Enter the period for watering"
                       Foreground="#F0F0EE"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0, 0, 0, 12" />

                <StackPanel Orientation="Horizontal">
                    <TextBox Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged}"
                         Width="80"
                         Background="#2C2C2E"
                         Foreground="#F0F0EE"
                         CaretBrush="#F0F0EE"
                         BorderThickness="1"
                         BorderBrush="#3A3D47"
                         Padding="8"
                         FontSize="14" />

                    <ComboBox Style="{StaticResource DarkComboBox}"
                              ItemsSource="{Binding AvailableUnits}"
                              SelectedValuePath="Key"
                              SelectedValue="{Binding SelectedUnit}"
                              Width="140"
                              Margin="10, 0, 0, 0"
                              Padding="8" />
                </StackPanel>

                <TextBlock Text="{Binding MaxAmount, StringFormat='max. {0}'}"
                           Foreground="#6A6A66"
                           FontSize="12"
                           Margin="0, 6, 0, 0" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type activeSteps:FertilizingStepViewModel}">
            <StackPanel Margin="20">
                <TextBlock Text="Enter the period for fertilizing (optional)"
                   Foreground="#F0F0EE"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0, 0, 0, 12" />

                <StackPanel Orientation="Horizontal">
                    <TextBox Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged}"
                     Width="80"
                     Background="#2C2C2E"
                     Foreground="#F0F0EE"
                     CaretBrush="#F0F0EE"
                     BorderThickness="1"
                     BorderBrush="#3A3D47"
                     Padding="8"
                     FontSize="14" />

                    <ComboBox Style="{StaticResource DarkComboBox}"
                              ItemsSource="{Binding AvailableUnits}"
                              SelectedValuePath="Key"
                              SelectedValue="{Binding SelectedUnit}"
                              Width="140"
                              Margin="10, 0, 0, 0"
                              Padding="8" />
                </StackPanel>

                <TextBlock Text="{Binding MaxAmount, StringFormat='max. {0}'}"
                           Foreground="#6A6A66"
                           FontSize="12"
                           Margin="0, 6, 0, 0" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type passiveSteps:SunlightStepViewModel}">
            <StackPanel Margin="20">
                <TextBlock Text="Enter the amount of sunlight (optional)"
                   Foreground="#F0F0EE"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0, 0, 0, 12" />

                <StackPanel Orientation="Horizontal">
                    <TextBox Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged}"
                     Width="80"
                     Background="#2C2C2E"
                     Foreground="#F0F0EE"
                     CaretBrush="#F0F0EE"
                     BorderThickness="1"
                     BorderBrush="#3A3D47"
                     Padding="8"
                     FontSize="14" />

                    <TextBlock Text="Hours"
                       Foreground="#8A8A86"
                       VerticalAlignment="Center"
                       Margin="8, 0, 0, 0" />

                    <ComboBox Style="{StaticResource DarkComboBox}"
                              ItemsSource="{Binding AvailablePeriods}"
                              SelectedValuePath="Key"
                              SelectedValue="{Binding SelectedPeriod}"
                              Width="140"
                              Margin="10, 0, 0, 0"
                              Padding="8" />
                </StackPanel>

                <TextBlock Text="{Binding MaxAmount, StringFormat='max. {0}'}"
                   Foreground="#6A6A66"
                   FontSize="12"
                   Margin="0, 6, 0, 0" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type steps:SummaryStepViewModel}">
            <StackPanel Margin="20">
                <TextBlock Text="Summary"
                           Foreground="#F0F0EE"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0, 0, 0, 12" />

                <TextBlock Text="{Binding PlantName}"
                           Foreground="#F0F0EE"
                           FontSize="14"
                           Margin="0, 0, 0, 6" />

                <TextBlock Text="{Binding Watering, StringFormat='Watering: {0}'}"
                           Foreground="#8A8A86"
                           FontSize="14"
                           Margin="0, 0, 0, 6" />

                <TextBlock Text="{Binding Fertilizing, StringFormat='Fertilizing: {0}'}"
                           Foreground="#8A8A86"
                           FontSize="14"
                           Margin="0, 0, 0, 6"
                           Visibility="{Binding HasFertilizing, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <TextBlock Text="{Binding Sunlight, StringFormat='Sunlight: {0}'}"
                           Foreground="#8A8A86"
                           FontSize="14"
                           Margin="0, 0, 0, 6"
                           Visibility="{Binding HasSunlight, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ContentControl Grid.Row="0" Content="{Binding CurrentStep}" />

        <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0, 12, 0, 0">

            <Button Style="{StaticResource MediumDarkButton}"
                    Content="Back"
                    Padding="10"
                    Margin="0, 0, 10, 0"
                    Command="{Binding BackCommand}" />

            <Button Style="{StaticResource MediumDarkButton}"
                Content="{Binding CurrentStep.NextButtonLabel}"
                Padding="10"
                Command="{Binding NextCommand}" />

            <Button Style="{StaticResource MediumDarkButton}"
                    Content="Cancel"
                    Margin="10, 0, 0, 0"
                    Padding="10"
                    Command="{Binding CancelCommand}" />
        </StackPanel>
    </Grid>
</Window>
